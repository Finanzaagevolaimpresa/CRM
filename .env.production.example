# Production placeholder file. Copy to the deployment environment and replace every placeholder.
DATABASE_URL="postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?schema=public"
APP_ENV="production"
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://crm.example.com"

AUTH_COOKIE_NAME="fai_crm_session"
AUTH_SECRET="<generate-a-long-random-secret-at-least-32-bytes>"

STORAGE_PROVIDER="local"
LOCAL_DOCUMENT_STORAGE_ROOT="/var/lib/fai-crm/documents"
DOCUMENT_MAX_BYTES="26214400"

# S3 placeholders reserved for environments where S3 support is implemented/configured.
S3_ENDPOINT="https://s3.example.com"
S3_REGION="eu-south-1"
S3_BUCKET="<private-documents-bucket>"
S3_ACCESS_KEY_ID="<s3-access-key-id>"
S3_SECRET_ACCESS_KEY="<s3-secret-access-key>"

AI_PROVIDER="mock"
AI_API_KEY="<server-side-ai-api-key-if-ai-provider-requires-it>"
AI_MODEL="gpt-4.1-mini"

WEBSITE_LEAD_WEBHOOK_SECRET="<generate-a-long-random-webhook-secret>"
