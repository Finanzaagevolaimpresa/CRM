generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  admin
  direzione
  commerciale
  consulente
  revisore
  backoffice
  amministrazione
  collaboratore_limitato
}

enum LeadStatus {
  nuovo
  da_contattare
  contattato
  qualificato
  non_qualificato
  appuntamento_fissato
  preanalisi_richiesta
  offerta_inviata
  contratto_inviato
  cliente_acquisito
  proposta_da_preparare
  proposta_inviata
  in_trattativa
  vinto
  perso
  archiviato
}

enum LeadSource {
  sito
  whatsapp
  referral
  campagna
  consulente
  manuale
  altro
}

enum LeadPriority {
  bassa
  media
  alta
  urgente
}

enum CommercialOfferStatus {
  bozza
  inviata
  accettata
  rifiutata
  scaduta
}

enum ClientType {
  persona_fisica
  ditta_individuale
  societa
  professionista
  soggetto_da_costituire
  associazione
  altro
}

enum ProjectStatus {
  idea
  raccolta_dati
  in_analisi
  preanalisi_pronta
  dossier_pronto
  contratto_in_attesa
  pratica_attiva
  chiuso
  archiviato
}

enum ExpenseCategory {
  attrezzature
  macchinari
  mezzi
  ristrutturazione
  opere_edili
  impianti
  software
  hardware
  marketing
  formazione
  consulenze
  liquidita
  acquisto_immobile
  affitto
  personale
  merce
  eventi
  spese_legali
  altro
}

enum RiskLevel {
  basso
  medio
  alto
  non_valutabile
}

enum MeasureStatus {
  aperta
  in_apertura
  chiusa
  a_sportello
  click_day
  a_graduatoria
  da_verificare
}

enum DocumentStatus {
  caricato
  classificato
  estratto
  da_verificare
  verificato
  respinto
  scaduto
  archiviato
}

enum ReviewStatus {
  da_avviare
  raccolta_dati
  analisi_ai
  bozza_generata
  da_revisionare
  revisionata
  approvata_internamente
  archiviata
}

enum DossierStatus {
  bozza_ai
  bozza_consulente
  in_revisione
  approvato_internamente
  consegnabile_manualmente
  consegnato_manualmente
  archiviato
}

enum ClientDossierType {
  pre_analisi
  dossier_cliente
  nota_interna
}

enum ClientDossierStatus {
  bozza
  revisionata
  archiviata
}

enum ContractStatus {
  da_preparare
  preparato
  inviato_manualmente
  firmato
  non_firmato
  annullato
  archiviato
}

enum PaymentStatus {
  da_incassare
  parziale
  incassato
  scaduto
  stornato
  rimborsato
}

enum AiOutputStatus {
  needs_review
  flagged
  approved
  rejected
  archived
}

enum ServiceStatus {
  richiesto
  pagato
  raccolta_documenti
  in_lavorazione
  bozza_ai
  revisione_umana
  consegnabile
  consegnato
  sospeso
  chiuso
  archiviato
}

enum OperationalServiceStatus {
  nuova
  pre_analisi
  documenti_richiesti
  documenti_ricevuti
  in_valutazione
  proposta_inviata
  domanda_in_preparazione
  domanda_presentata
  in_istruttoria
  approvata_deliberata
  respinta_non_procedibile
  rendicontazione
  chiusa
  archiviata
}

enum ChecklistItemStatus {
  da_richiedere
  richiesto
  ricevuto
  validato
  non_necessario
}

enum ServiceArea {
  anagrafica
  bancabilita
  finanziamento_aziendale
  bandi_finanza_agevolata
  progetto_investimento
  contratti
  pagamenti
  dossier
  output_ai
  altro
}

enum TaskStatus {
  aperta
  in_lavorazione
  completata
  annullata
}

enum TaskPriority {
  bassa
  media
  alta
  urgente
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         RoleCode
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastLoginAt  DateTime?
}

model Lead {
  id                 String       @id @default(cuid())
  firstName          String
  lastName           String
  companyName        String?
  contactPerson      String?
  phone              String?
  email              String?
  source             String?
  leadSource         LeadSource   @default(manuale)
  region             String?
  province           String?
  city               String?
  interest           String?
  declaredInvestment Decimal?
  requestedAmount    Decimal?
  availableBudget    Decimal?
  status             LeadStatus   @default(nuovo)
  priority           LeadPriority @default(media)
  commercialStatus   String?
  assignedToId       String?
  nextAction         DateTime?
  nextActionNote     String?
  nextActionDate     DateTime?
  notes              String?
  commercialProposal String?
  clientId           String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?
}

model CommercialOffer {
  id            String                @id @default(cuid())
  leadId        String?
  clientId      String?
  title         String
  taxableAmount Decimal
  vatAmount     Decimal
  totalAmount   Decimal
  status        CommercialOfferStatus @default(bozza)
  notes         String?
  createdById   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?
}

model Client {
  id           String     @id @default(cuid())
  type         ClientType
  displayName  String
  leadId       String?
  status       String     @default("attivo")
  salesOwnerId String?
  consultantId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
}

model Company {
  id                String    @id @default(cuid())
  clientId          String
  name              String
  vatNumber         String?
  taxCode           String?
  rea               String?
  pec               String?
  legalAddress      String?
  operatingAddress  String?
  region            String?
  province          String?
  city              String?
  legalForm         String?
  atecoCode         String?
  atecoDescription  String?
  incorporationDate DateTime?
  activityStartDate DateTime?
  activityStatus    String?
  employees         Int?
  annualRevenue     Decimal?
  durcStatus        String?
  taxRegime         String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
}

model Person {
  id        String    @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  taxCode   String?
  notes     String?
  deletedAt DateTime?
}

model CompanyPerson {
  id               String   @id @default(cuid())
  companyId        String
  personId         String
  role             String
  ownershipPercent Decimal?
}

model IncorporationSubject {
  id                    String    @id @default(cuid())
  promoterClientId      String?
  hypotheticalLegalForm String?
  hypotheticalAteco     String?
  plannedActivity       String?
  region                String?
  province              String?
  expectedStartDate     DateTime?
  estimatedInvestment   Decimal?
  status                String?
  issues                String?
  deletedAt             DateTime?
}

model Project {
  id                     String        @id @default(cuid())
  clientId               String
  companyId              String?
  incorporationSubjectId String?
  title                  String
  description            String?
  totalInvestment        Decimal?
  requestedAmount        Decimal?
  startTiming            String?
  region                 String?
  province               String?
  sector                 String?
  status                 ProjectStatus @default(idea)
  priority               String        @default("media")
  scenarioA              String?
  scenarioB              String?
  blockingConditions     String?
  consultantId           String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?
}

model ProjectExpense {
  id                  String          @id @default(cuid())
  projectId           String
  category            ExpenseCategory
  description         String
  amount              Decimal
  estimated           Boolean         @default(true)
  potentiallyEligible Boolean         @default(false)
  eligibilityNotes    String?
  priority            String?
}

model BankabilityAssessment {
  id                         String    @id @default(cuid())
  clientId                   String
  companyId                  String?
  projectId                  String?
  declaredCrif               String?
  declaredCentralRisk        String?
  protestsOrLiens            String?
  paymentDelays              String?
  activeLoans                String?
  taxDebts                   String?
  socialSecurityDebts        String?
  revenue                    Decimal?
  ebitda                     Decimal?
  netProfit                  Decimal?
  equity                     Decimal?
  estimatedCashflow          Decimal?
  estimatedDscr              Decimal?
  monthlyRent                Decimal?
  existingMonthlyInstalments Decimal?
  availableGuarantees        String?
  riskLevel                  RiskLevel @default(non_valutabile)
  riskRationale              String?
  dataCompleteness           Int       @default(0)
  humanReviewStatus          String    @default("da_revisionare")
  updatedAt                  DateTime  @updatedAt
}

model GrantAssessment {
  id        String   @id @default(cuid())
  projectId String
  summary   String?
  createdAt DateTime @default(now())
}

model MeasureMatch {
  id                     String        @id @default(cuid())
  grantAssessmentId      String
  internalMeasureName    String
  measureStatus          MeasureStatus @default(da_verificare)
  opensAt                DateTime?
  closesAt               DateTime?
  expectedResult         String?
  expectedBenefitAmount  Decimal?
  expectedBenefitPercent Decimal?
  difficulty             String?
  difficultyRationale    String?
  eligibleExpenses       String?
  ineligibleExpenses     String?
  blockingConditions     String?
  requiredDocuments      String?
  sourceStatus           String?
  officialSourceUrl      String?
  verificationRequired   Boolean       @default(true)
  notes                  String?
}

model CumulabilityAssessment {
  id                String  @id @default(cuid())
  projectId         String
  grantAssessmentId String?
  summary           String?
  legalResult       String?
  technicalResult   String?
  deMinimisRisk     String?
  rnaRisk           String?
  doubleFundingRisk String?
  timingConflicts   String?
  conclusion        String?
  humanReviewStatus String  @default("da_revisionare")
}

model Document {
  id                    String         @id @default(cuid())
  clientId              String?
  companyId             String?
  projectId             String?
  clientServiceId       String?
  serviceArea           ServiceArea    @default(altro)
  documentCategory      String         @default("altro")
  type                  String
  title                 String
  fileName              String
  mimeType              String
  sizeBytes             Int
  storagePath           String
  checksum              String?
  uploadedById          String
  status                DocumentStatus @default(caricato)
  visibilityLevel       String         @default("interno")
  containsSensitiveData Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  validUntil            DateTime?
  deletedAt             DateTime?
}

model DocumentChecklistItem {
  id              String              @id @default(cuid())
  clientId        String
  clientServiceId String?
  projectId       String?
  title           String
  notes           String?
  status          ChecklistItemStatus @default(da_richiedere)
  documentId      String?
  active          Boolean             @default(true)
  createdById     String?
  updatedById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  @@index([clientId])
  @@index([clientServiceId])
  @@index([projectId])
  @@index([documentId])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  storagePath String
  checksum    String?
  createdAt   DateTime @default(now())
}

model DocumentExtraction {
  id            String   @id @default(cuid())
  documentId    String
  extractedJson Json?
  extractedText String?
  status        String   @default("da_verificare")
  createdAt     DateTime @default(now())
}

model VisuraAnalysis {
  id                String   @id @default(cuid())
  documentId        String
  companyId         String?
  findings          Json?
  humanReviewStatus String   @default("da_revisionare")
  createdAt         DateTime @default(now())
}

model PreAnalysis {
  id                       String       @id @default(cuid())
  projectId                String
  clientId                 String
  companyId                String?
  status                   ReviewStatus @default(da_avviare)
  internalSummary          String?
  clientReadySummary       String?
  scenarioA                String?
  scenarioB                String?
  blockingConditions       String?
  requiredDocuments        String?
  nextActions              String?
  commercialRecommendation String?
  aiRunId                  String?
  reviewedById             String?
  approvedById             String?
  approvedAt               DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

model Dossier {
  id              String        @id @default(cuid())
  preAnalysisId   String?
  projectId       String
  clientId        String
  title           String
  type            String
  status          DossierStatus @default(bozza_ai)
  markdownContent String?
  jsonContent     Json?
  version         Int           @default(1)
  aiRunId         String?
  modifiedById    String?
  reviewedById    String?
  approvedById    String?
  approvedAt      DateTime?
  docxExportPath  String?
  pdfExportPath   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ClientDossier {
  id              String              @id @default(cuid())
  clientId        String
  clientServiceId String?
  projectId       String?
  title           String
  type            ClientDossierType   @default(pre_analisi)
  content         String
  status          ClientDossierStatus @default(bozza)
  createdById     String
  updatedById     String?
  archivedById    String?
  archivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([clientId])
  @@index([clientServiceId])
  @@index([projectId])
  @@index([status])
}

model Contract {
  id                 String         @id @default(cuid())
  clientId           String
  projectId          String?
  contractNumber     String         @unique
  serviceName        String
  serviceDescription String?
  taxableAmount      Decimal
  vatAmount          Decimal
  totalAmount        Decimal
  status             ContractStatus @default(da_preparare)
  sentAt             DateTime?
  signedAt           DateTime?
  signedDocumentId   String?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Payment {
  id                   String        @id @default(cuid())
  contractId           String
  clientId             String
  taxableAmount        Decimal
  vatAmount            Decimal
  totalAmount          Decimal
  method               String?
  status               PaymentStatus @default(da_incassare)
  dueDate              DateTime?
  collectedAt          DateTime?
  accountingDocumentId String?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Task {
  id              String       @id @default(cuid())
  clientId        String?
  companyId       String?
  projectId       String?
  clientServiceId String?
  title           String
  description     String?
  type            String?
  priority        TaskPriority @default(media)
  status          TaskStatus   @default(aperta)
  assignedToId    String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([clientId])
  @@index([clientServiceId])
  @@index([projectId])
  @@index([assignedToId])
  @@index([dueAt])
}

model Deadline {
  id         String   @id @default(cuid())
  title      String
  entityType String
  entityId   String
  dueAt      DateTime
  status     String   @default("aperta")
}

model AiAgent {
  id                    String   @id @default(cuid())
  code                  String   @unique
  name                  String
  description           String   @default("")
  operationalScope      String   @default("")
  systemPrompt          String   @default("")
  requiredDataChecklist Json     @default("[]")
  expectedOutput        String   @default("")
  toneStyle             String   @default("")
  active                Boolean  @default(true)
  provider              String   @default("mock")
  futureModel           String?
  promptVersion         String
  inputSchema           Json
  outputSchema          Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AiRun {
  id                      String   @id @default(cuid())
  agentId                 String
  clientId                String?
  clientServiceId         String?
  projectId               String?
  status                  String   @default("completed")
  input                   Json?
  output                  Json?
  operationalInstructions String?
  createdById             String?
  createdAt               DateTime @default(now())

  @@index([clientId])
  @@index([clientServiceId])
  @@index([projectId])
}

model AiOutput {
  id                  String         @id @default(cuid())
  aiRunId             String
  clientId            String?
  clientServiceId     String?
  projectId           String?
  title               String
  content             String
  status              AiOutputStatus @default(needs_review)
  requiresHumanReview Boolean        @default(true)
  forbiddenPhrases    Json?
  approvedById        String?
  approvedAt          DateTime?
  reviewedById        String?
  reviewedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([clientId])
  @@index([clientServiceId])
  @@index([projectId])
}

model AiAgentMessage {
  id        String   @id @default(cuid())
  aiRunId   String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model ServiceCatalog {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  category     String
  basePrice    Decimal?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ClientService {
  id                String                   @id @default(cuid())
  clientId          String
  companyId         String?
  projectId         String?
  serviceCatalogId  String
  contractId        String?
  paymentId         String?
  status            ServiceStatus            @default(richiesto)
  operationalStatus OperationalServiceStatus @default(nuova)
  statusUpdatedAt   DateTime                 @default(now())
  practiceType      String?
  requestedAmount   Decimal?
  plannedInvestment Decimal?
  openedAt          DateTime                 @default(now())
  operationalNotes  String?
  paymentStatus     PaymentStatus            @default(da_incassare)
  assignedToId      String?
  purchasedAt       DateTime                 @default(now())
  dueDate           DateTime?
  completedAt       DateTime?
  internalNotes     String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?

  @@index([operationalStatus])
  @@index([statusUpdatedAt])
}

model CorporateFinancingAssessment {
  id                     String   @id @default(cuid())
  clientId               String
  companyId              String?
  projectId              String?
  clientServiceId        String?
  requestedAmount        Decimal?
  purpose                String?
  timing                 String?
  ordinaryInstruments    String?
  mortgage               String?
  unsecuredLoan          String?
  leasing                String?
  factoring              String?
  invoiceAdvance         String?
  creditLines            String?
  mcc                    String?
  guarantees             String?
  fundingNeed            String?
  sustainableInstallment Decimal?
  dscrCashflow           String?
  existingDebts          String?
  criticalIssues         String?
  scenarioA              String?
  scenarioB              String?
  nextAction             String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  event      String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}
