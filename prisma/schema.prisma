generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  admin
  direzione
  commerciale
  consulente
  revisore
  backoffice
  amministrazione
}

enum LeadStatus {
  nuovo
  da_contattare
  contattato
  qualificato
  non_qualificato
  appuntamento_fissato
  preanalisi_richiesta
  offerta_inviata
  contratto_inviato
  cliente_acquisito
  perso
  archiviato
}

enum ClientType {
  persona_fisica
  ditta_individuale
  societa
  professionista
  soggetto_da_costituire
  associazione
  altro
}

enum ProjectStatus {
  idea
  raccolta_dati
  in_analisi
  preanalisi_pronta
  dossier_pronto
  contratto_in_attesa
  pratica_attiva
  chiuso
  archiviato
}

enum ExpenseCategory {
  attrezzature
  macchinari
  mezzi
  ristrutturazione
  opere_edili
  impianti
  software
  hardware
  marketing
  formazione
  consulenze
  liquidita
  acquisto_immobile
  affitto
  personale
  merce
  eventi
  spese_legali
  altro
}

enum RiskLevel {
  basso
  medio
  alto
  non_valutabile
}

enum MeasureStatus {
  aperta
  in_apertura
  chiusa
  a_sportello
  click_day
  a_graduatoria
  da_verificare
}

enum DocumentStatus {
  caricato
  classificato
  estratto
  da_verificare
  verificato
  respinto
  scaduto
  archiviato
}

enum ReviewStatus {
  da_avviare
  raccolta_dati
  analisi_ai
  bozza_generata
  da_revisionare
  revisionata
  approvata_internamente
  archiviata
}

enum DossierStatus {
  bozza_ai
  bozza_consulente
  in_revisione
  approvato_internamente
  consegnabile_manualmente
  consegnato_manualmente
  archiviato
}

enum ContractStatus {
  da_preparare
  preparato
  inviato_manualmente
  firmato
  non_firmato
  annullato
  archiviato
}

enum PaymentStatus {
  da_incassare
  parziale
  incassato
  scaduto
  stornato
  rimborsato
}

enum AiOutputStatus {
  needs_review
  flagged
  approved
  rejected
  archived
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         RoleCode
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}

model Lead {
  id                 String     @id @default(cuid())
  firstName          String
  lastName           String
  phone              String?
  email              String?
  source             String?
  region             String?
  province           String?
  interest           String?
  declaredInvestment Decimal?
  status             LeadStatus @default(nuovo)
  commercialStatus   String?
  assignedToId       String?
  nextAction         DateTime?
  notes              String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?
}

model Client {
  id           String     @id @default(cuid())
  type         ClientType
  displayName  String
  leadId       String?
  status       String     @default("attivo")
  salesOwnerId String?
  consultantId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
}

model Company {
  id                String    @id @default(cuid())
  clientId          String
  name              String
  vatNumber         String?
  taxCode           String?
  rea               String?
  pec               String?
  legalAddress      String?
  operatingAddress  String?
  region            String?
  province          String?
  city              String?
  legalForm         String?
  atecoCode         String?
  atecoDescription  String?
  incorporationDate DateTime?
  activityStartDate DateTime?
  activityStatus    String?
  employees         Int?
  annualRevenue     Decimal?
  durcStatus        String?
  taxRegime         String?
  notes             String?
  deletedAt         DateTime?
}

model Person {
  id        String    @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  taxCode   String?
  notes     String?
  deletedAt DateTime?
}

model CompanyPerson {
  id               String   @id @default(cuid())
  companyId        String
  personId         String
  role             String
  ownershipPercent Decimal?
}

model IncorporationSubject {
  id                    String    @id @default(cuid())
  promoterClientId      String?
  hypotheticalLegalForm String?
  hypotheticalAteco     String?
  plannedActivity       String?
  region                String?
  province              String?
  expectedStartDate     DateTime?
  estimatedInvestment   Decimal?
  status                String?
  issues                String?
  deletedAt             DateTime?
}

model Project {
  id                     String        @id @default(cuid())
  clientId               String
  companyId              String?
  incorporationSubjectId String?
  title                  String
  description            String?
  totalInvestment        Decimal?
  requestedAmount        Decimal?
  startTiming            String?
  region                 String?
  province               String?
  sector                 String?
  status                 ProjectStatus @default(idea)
  priority               String        @default("media")
  scenarioA              String?
  scenarioB              String?
  blockingConditions     String?
  consultantId           String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?
}

model ProjectExpense {
  id                  String          @id @default(cuid())
  projectId           String
  category            ExpenseCategory
  description         String
  amount              Decimal
  estimated           Boolean         @default(true)
  potentiallyEligible Boolean         @default(false)
  eligibilityNotes    String?
  priority            String?
}

model BankabilityAssessment {
  id                          String    @id @default(cuid())
  clientId                    String
  companyId                   String?
  projectId                   String?
  declaredCrif                String?
  declaredCentralRisk         String?
  protestsOrLiens             String?
  paymentDelays               String?
  activeLoans                 String?
  taxDebts                    String?
  socialSecurityDebts         String?
  revenue                     Decimal?
  ebitda                      Decimal?
  netProfit                   Decimal?
  equity                      Decimal?
  estimatedCashflow           Decimal?
  estimatedDscr               Decimal?
  monthlyRent                 Decimal?
  existingMonthlyInstalments  Decimal?
  availableGuarantees         String?
  riskLevel                   RiskLevel @default(non_valutabile)
  riskRationale               String?
  dataCompleteness            Int       @default(0)
  humanReviewStatus           String    @default("da_revisionare")
  updatedAt                   DateTime  @updatedAt
}

model GrantAssessment {
  id        String   @id @default(cuid())
  projectId String
  summary   String?
  createdAt DateTime @default(now())
}

model MeasureMatch {
  id                     String        @id @default(cuid())
  grantAssessmentId      String
  internalMeasureName    String
  measureStatus          MeasureStatus @default(da_verificare)
  opensAt                DateTime?
  closesAt               DateTime?
  expectedResult         String?
  expectedBenefitAmount  Decimal?
  expectedBenefitPercent Decimal?
  difficulty             String?
  difficultyRationale    String?
  eligibleExpenses       String?
  ineligibleExpenses     String?
  blockingConditions     String?
  requiredDocuments      String?
  sourceStatus           String?
  officialSourceUrl      String?
  verificationRequired   Boolean       @default(true)
  notes                  String?
}

model CumulabilityAssessment {
  id                String @id @default(cuid())
  projectId         String
  grantAssessmentId String?
  summary           String?
  legalResult       String?
  technicalResult   String?
  deMinimisRisk     String?
  rnaRisk           String?
  doubleFundingRisk String?
  timingConflicts   String?
  conclusion        String?
  humanReviewStatus String @default("da_revisionare")
}

model Document {
  id                    String         @id @default(cuid())
  clientId              String?
  companyId             String?
  projectId             String?
  type                  String
  title                 String
  fileName              String
  mimeType              String
  sizeBytes             Int
  storagePath           String
  checksum              String?
  uploadedById          String
  status                DocumentStatus @default(caricato)
  visibilityLevel       String         @default("interno")
  containsSensitiveData Boolean        @default(false)
  createdAt             DateTime       @default(now())
  deletedAt             DateTime?
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  storagePath String
  checksum    String?
  createdAt   DateTime @default(now())
}

model DocumentExtraction {
  id            String   @id @default(cuid())
  documentId    String
  extractedJson Json?
  extractedText String?
  status        String   @default("da_verificare")
  createdAt     DateTime @default(now())
}

model VisuraAnalysis {
  id                String   @id @default(cuid())
  documentId        String
  companyId         String?
  findings          Json?
  humanReviewStatus String   @default("da_revisionare")
  createdAt         DateTime @default(now())
}

model PreAnalysis {
  id                       String       @id @default(cuid())
  projectId                String
  clientId                 String
  companyId                String?
  status                   ReviewStatus @default(da_avviare)
  internalSummary          String?
  clientReadySummary       String?
  scenarioA                String?
  scenarioB                String?
  blockingConditions       String?
  requiredDocuments        String?
  nextActions              String?
  commercialRecommendation String?
  aiRunId                  String?
  reviewedById             String?
  approvedById             String?
  approvedAt               DateTime?
}

model Dossier {
  id              String        @id @default(cuid())
  preAnalysisId   String?
  projectId       String
  clientId        String
  title           String
  type            String
  status          DossierStatus @default(bozza_ai)
  markdownContent String?
  jsonContent     Json?
  version         Int           @default(1)
  aiRunId         String?
  modifiedById    String?
  reviewedById    String?
  approvedById    String?
  approvedAt      DateTime?
  docxExportPath  String?
  pdfExportPath   String?
}

model Contract {
  id                 String         @id @default(cuid())
  clientId           String
  projectId          String?
  contractNumber     String         @unique
  serviceName        String
  serviceDescription String?
  taxableAmount      Decimal
  vatAmount          Decimal
  totalAmount        Decimal
  status             ContractStatus @default(da_preparare)
  sentAt             DateTime?
  signedAt           DateTime?
  signedDocumentId   String?
  notes              String?
}

model Payment {
  id                   String        @id @default(cuid())
  contractId           String
  clientId             String
  taxableAmount        Decimal
  vatAmount            Decimal
  totalAmount          Decimal
  method               String?
  status               PaymentStatus @default(da_incassare)
  dueDate              DateTime?
  collectedAt          DateTime?
  accountingDocumentId String?
  notes                String?
}

model Task {
  id           String    @id @default(cuid())
  clientId     String?
  companyId    String?
  projectId    String?
  title        String
  description  String?
  type         String?
  priority     String    @default("media")
  status       String    @default("aperto")
  assignedToId String?
  dueAt        DateTime?
  completedAt  DateTime?
  createdById  String?
}

model Deadline {
  id         String   @id @default(cuid())
  title      String
  entityType String
  entityId   String
  dueAt      DateTime
  status     String   @default("aperta")
}

model AiAgent {
  id            String  @id @default(cuid())
  code          String  @unique
  name          String
  promptVersion String
  inputSchema   Json
  outputSchema  Json
  active        Boolean @default(true)
}

model AiRun {
  id          String   @id @default(cuid())
  agentId     String
  status      String   @default("completed")
  input       Json?
  output      Json?
  createdById String?
  createdAt   DateTime @default(now())
}

model AiOutput {
  id                  String         @id @default(cuid())
  aiRunId             String
  title               String
  content             String
  status              AiOutputStatus @default(needs_review)
  requiresHumanReview Boolean        @default(true)
  forbiddenPhrases    Json?
  approvedById        String?
  approvedAt          DateTime?
  reviewedById        String?
  reviewedAt          DateTime?
  createdAt           DateTime       @default(now())
}

model AiAgentMessage {
  id        String   @id @default(cuid())
  aiRunId   String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  event      String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}
