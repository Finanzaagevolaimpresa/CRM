DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fai_crm?schema=public"
APP_ENV="development"
AUTH_COOKIE_NAME="fai_crm_session"
AUTH_SECRET="replace-with-a-long-random-secret"
# Storage runtime attuale: usare local. S3/cloud storage è un TODO e non è ancora supportato/attivo a runtime.
STORAGE_PROVIDER="local"
S3_ENDPOINT=""
S3_REGION="eu-south-1"
S3_BUCKET="fai-crm-private"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Compatibilità/diagnostica; i run operativi usano provider/modello del singolo agente.
AI_PROVIDER="mock"
AI_API_KEY=""
AI_MODEL=""
# Control Plane: entrambi i gate (env + database) devono essere attivi per usare provider esterni.
# La allowlist vuota mantiene il runtime fail-closed: nessun modello esterno è implicitamente autorizzato.
AI_EXTERNAL_PROVIDERS_ENABLED="false"
AI_ALLOWED_MODELS=""
# Dormant Worker Process Foundation: entrypoint solo manuale; 0/missing mantiene la shell dormiente.
# FOUNDATION_LOCKED_V1 rifiuta 1 e qualsiasi valore non canonico.
AI_ORCHESTRATOR_WORKER_ENABLED="0"
WEBSITE_LEAD_WEBHOOK_SECRET=""
