DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fai_crm?schema=public"
APP_ENV="development"
AUTH_COOKIE_NAME="fai_crm_session"
AUTH_SECRET="replace-with-a-long-random-secret"
# Storage runtime attuale: usare local. S3/cloud storage è un TODO e non è ancora supportato/attivo a runtime.
STORAGE_PROVIDER="local"
S3_ENDPOINT=""
S3_REGION="eu-south-1"
S3_BUCKET="fai-crm-private"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
AI_PROVIDER="mock"
AI_API_KEY=""
AI_MODEL="gpt-4.1-mini"
WEBSITE_LEAD_WEBHOOK_SECRET=""
